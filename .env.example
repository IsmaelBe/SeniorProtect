# Copie ce fichier en .env pour le dev local, puis remplis tes vraies valeurs.

# Secret pour signer les jetons (mets une longue chaîne aléatoire)
SECRET_KEY=change-me

# URL publique du backend (liens pièges + redirect OAuth)
BASE_URL=http://localhost:8000

# URL du front Lovable (redirection après connexion Gmail réussie)
FRONT_URL=http://localhost:8000

# --- OAuth Google (pour lire le vrai Gmail) ---
# Créés dans Google Cloud Console > API et services > Identifiants > ID client OAuth (type Web)
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxx
# URI de redirection à enregistrer dans Google : {BASE_URL}/gmail/callback

# Base de données.
# Option A (Postgres local) : renseigne MDP_BDD ; l'URL est construite dans
#   database.py -> postgresql://$USER:$MDP_BDD@localhost/ProtectNet
# MDP_BDD=ton_mot_de_passe_postgres
# Option B (SQLite local) : ne rien mettre.
# Option C (Render/prod) : DATABASE_URL est fournie automatiquement.
# DATABASE_URL=postgresql://...
